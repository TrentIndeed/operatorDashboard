# ===== GitHub =====
# Generate at: https://github.com/settings/tokens (scope: repo)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-github-username
MESH2PARAM_REPO=mesh2param

# ===== Google / YouTube =====
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Enable YouTube Data API v3
# Add redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-your_secret
# This gets auto-filled after running the OAuth flow at http://localhost:8000/auth/google/login
GOOGLE_REFRESH_TOKEN=

# ===== TikTok =====
# Copy from browser DevTools: tiktok.com → Application → Cookies → sessionid
TIKTOK_SESSION_ID=

# ===== Twitter/X =====
# Create at: https://developer.x.com/en/portal/dashboard
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
# Optional (OAuth 2.0)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ===== Instagram (not yet implemented) =====
INSTAGRAM_SESSION_ID=

# ===== Dashboard Login =====
DASHBOARD_USER=123
DASHBOARD_PASS=123

# ===== App Config =====
DATABASE_URL=sqlite:///./data/operator.db
WAITLIST_DB_PATH=./data/waitlist.db

# ===== n8n Automation =====
N8N_WEBHOOK_URL=http://localhost:5678
N8N_USER=admin
N8N_PASSWORD=changeme

# ===== Email (for daily briefing) =====
EMAIL_TO=you@example.com

# ===== WhatsApp Business API =====
# Get from Meta Business Suite: https://business.facebook.com/
WHATSAPP_PHONE_ID=
WHATSAPP_TO=+1234567890
WHATSAPP_ACCESS_TOKEN=

# ===== Optional =====
STRIPE_SECRET_KEY=
