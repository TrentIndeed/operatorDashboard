FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

# Build args become NEXT_PUBLIC_ env vars at build time
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ARG NEXT_PUBLIC_API_USER=
ARG NEXT_PUBLIC_API_PASS=
ARG NEXT_PUBLIC_DISPLAY_NAME=Operator
ARG NEXT_PUBLIC_TAGLINE=solo founder mode
ARG NEXT_PUBLIC_INITIALS=OP

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_USER=$NEXT_PUBLIC_API_USER
ENV NEXT_PUBLIC_API_PASS=$NEXT_PUBLIC_API_PASS
ENV NEXT_PUBLIC_DISPLAY_NAME=$NEXT_PUBLIC_DISPLAY_NAME
ENV NEXT_PUBLIC_TAGLINE=$NEXT_PUBLIC_TAGLINE
ENV NEXT_PUBLIC_INITIALS=$NEXT_PUBLIC_INITIALS

RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]
